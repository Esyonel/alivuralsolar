<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Ali Vural Solar</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-main" id="adminMain">
    <div class="admin-topbar">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="admin-user"><i class="fas fa-user-circle"></i> <span><%= user.username %></span></div>
    </div>
    <div class="admin-content">
      <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>

      <div class="content-header">
        <h1>Hizmet Yönetimi</h1>
        <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'"><i class="fas fa-plus"></i> Yeni Hizmet</button>
      </div>

      <div class="table-responsive">
        <table class="admin-table">
          <thead><tr><th>Sıra</th><th>Başlık</th><th>İkon</th><th>İşlem</th></tr></thead>
          <tbody>
            <% services.forEach(function(s) { %>
            <tr>
              <td><%= s.sort_order %></td>
              <td><strong><%= s.title %></strong></td>
              <td><i class="<%= s.icon %>"></i> <%= s.icon %></td>
              <td class="actions">
                <button class="btn btn-sm btn-info" onclick='editService(<%= JSON.stringify(s) %>)'><i class="fas fa-edit"></i></button>
                <form method="POST" action="/admin/services/<%= s.id %>/delete" style="display:inline;" onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                  <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="modal" id="addModal">
    <div class="modal-content modal-lg">
      <div class="modal-header"><h3>Yeni Hizmet</h3><button class="modal-close" onclick="document.getElementById('addModal').style.display='none'">&times;</button></div>
      <form method="POST" action="/admin/services" enctype="multipart/form-data">
        <div class="form-group"><label>Başlık *</label><input type="text" name="title" required class="form-control"></div>
        <div class="form-group"><label>Açıklama</label><textarea name="description" rows="3" class="form-control"></textarea></div>
        <div class="form-row">
          <div class="form-group"><label>İkon (Font Awesome)</label><input type="text" name="icon" class="form-control" placeholder="fas fa-solar-panel"></div>
          <div class="form-group"><label>Sıra</label><input type="number" name="sort_order" value="0" class="form-control"></div>
        </div>
        <div class="form-group"><label>Görsel</label><input type="file" name="image" accept="image/*" class="form-control"></div>
        <button type="submit" class="btn btn-primary btn-block">Ekle</button>
      </form>
    </div>
  </div>

  <div class="modal" id="editModal">
    <div class="modal-content modal-lg">
      <div class="modal-header"><h3>Hizmeti Düzenle</h3><button class="modal-close" onclick="document.getElementById('editModal').style.display='none'">&times;</button></div>
      <form method="POST" id="editServForm" enctype="multipart/form-data">
        <div class="form-group"><label>Başlık *</label><input type="text" name="title" id="editTitle" required class="form-control"></div>
        <div class="form-group"><label>Açıklama</label><textarea name="description" id="editDesc" rows="3" class="form-control"></textarea></div>
        <div class="form-row">
          <div class="form-group"><label>İkon</label><input type="text" name="icon" id="editIcon" class="form-control"></div>
          <div class="form-group"><label>Sıra</label><input type="number" name="sort_order" id="editSort" class="form-control"></div>
        </div>
        <div class="form-group"><label>Yeni Görsel (opsiyonel)</label><input type="file" name="image" accept="image/*" class="form-control"></div>
        <button type="submit" class="btn btn-primary btn-block">Güncelle</button>
      </form>
    </div>
  </div>

  <script src="/js/admin.js"></script>
  <script>
    function editService(s) {
      document.getElementById('editServForm').action = '/admin/services/' + s.id;
      document.getElementById('editTitle').value = s.title;
      document.getElementById('editDesc').value = s.description || '';
      document.getElementById('editIcon').value = s.icon || '';
      document.getElementById('editSort').value = s.sort_order;
      document.getElementById('editModal').style.display = 'flex';
    }
  </script>
</body>
</html>
