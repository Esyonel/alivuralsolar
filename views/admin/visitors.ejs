<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Ali Vural Enerji</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-main" id="adminMain">
    <div class="admin-topbar">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="admin-user"><i class="fas fa-user-circle"></i> <span><%= user.username %></span></div>
    </div>
    <div class="admin-content">
      <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>

      <h1><i class="fas fa-globe"></i> Ziyaretçi İstatistikleri</h1>

      <div class="stats-cards" style="margin-bottom:30px;">
        <div class="stat-card">
          <div class="stat-card-icon" style="background:#4CAF50;"><i class="fas fa-users"></i></div>
          <div class="stat-card-info">
            <h3><%= totalVisitors %></h3>
            <p>Toplam Ziyaret</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon" style="background:#FF9800;"><i class="fas fa-circle"></i></div>
          <div class="stat-card-info">
            <h3><%= todayVisitors %></h3>
            <p>Bugünkü Ziyaret</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon" style="background:#2196F3;"><i class="fas fa-globe-americas"></i></div>
          <div class="stat-card-info">
            <h3><%= uniqueCountries %></h3>
            <p>Farklı Ülke</p>
          </div>
        </div>
      </div>

      <h2>Son Ziyaretçiler</h2>
      <% if (visitors.length === 0) { %>
        <p class="text-muted">Henüz ziyaretçi kaydı yok.</p>
      <% } else { %>
      <div class="table-responsive">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Tarih</th>
              <th>IP</th>
              <th>Ülke</th>
              <th>Şehir</th>
              <th>Sayfa</th>
            </tr>
          </thead>
          <tbody>
            <% visitors.forEach(function(v) { %>
            <tr>
              <td><%= new Date(v.created_at).toLocaleString('tr-TR') %></td>
              <td><code><%= v.ip %></code></td>
              <td><%= v.country %></td>
              <td><%= v.city %></td>
              <td><%= v.page %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
  <script src="/js/admin.js"></script>
</body>
</html>
